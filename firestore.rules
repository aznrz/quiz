rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    // ─── Per-user progress and favorites (self only) ────────────────
    match /users/{uid} {
      allow read, write: if isSelf(uid);

      match /data/{key}              { allow read, write: if isSelf(uid); }
      match /profile/{docId}         { allow read, write: if isSelf(uid); }
      match /reflections/{qid}       { allow read, write: if isSelf(uid); }
      match /question_feedback/{id}  { allow read, write: if isSelf(uid); }
    }

    // ─── Shared aggregates and stats (authed users only) ─────────────
    match /analytics/{uid}           { allow read, write: if isSelf(uid); }
    match /daily_stats/{date}        { allow read, write: if signedIn(); }
    match /question_stats/{qid}      { allow read, write: if signedIn(); }

    // ─── Direct client-side events logging (append-only) ────────────
    match /events/{eventId}          { allow create: if signedIn(); allow read, update, delete: if false; }

    // ─── Global Configuration (public read, no client writes) ───────
    match /app_config/{docId}        { allow read: if true; allow write: if false; }
  }
}
