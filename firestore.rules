// Firestore security rules — exams-quiz-db.
// ACCESS-PLAN Step 1A.1.c. Two principles:
//   1) Mirror existing client behavior on already-used collections so
//      deploy doesn't lock anyone out.
//   2) Lock down ALL new access-control collections — those are written
//      exclusively by Cloud Functions (admin SDK bypasses rules).
//
// TODO (not in 1A.1.c scope):
//   - `analytics/*` currently allows any authed user to read all docs
//     (the admin dashboard depends on it). Tighten when an admin-callable
//     replacement for getAllAnalytics lands.
//   - `subscriptions` will need a self-read rule via uid field when
//     Phase 3 payments arrive.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    // ─── Per-user data (self only) ──────────────────────────────────
    match /users/{uid} {
      allow read, write: if isSelf(uid);

      match /data/{key}              { allow read, write: if isSelf(uid); }
      match /profile/{docId}         { allow read, write: if isSelf(uid); }
      match /reflections/{qid}       { allow read, write: if isSelf(uid); }
      match /question_feedback/{id}  { allow read, write: if isSelf(uid); }

      // Quota — server-only via admin SDK. Deny client.
      match /quota/{date}            { allow read, write: if false; }

      // Access control — read self, write only via Cloud Functions.
      match /access_grants/{grantId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }
    }

    // ─── Shared aggregates (keep existing behavior) ─────────────────
    match /analytics/{uid}           { allow read, write: if signedIn(); }
    match /daily_stats/{date}        { allow read, write: if signedIn(); }
    match /question_stats/{qid}      { allow read, write: if signedIn(); }

    // ─── Admin draft editor (self namespace under drafts/{uid}/**) ──
    match /drafts/{uid}/{document=**} { allow read, write: if isSelf(uid); }

    // ─── Live overlay for admin-published questions (callable-only) ─
    // Only the `publishQuestionToLive` / `getQuestionsAllV2` callable
    // functions (admin SDK) read/write here. Client SDKs are blocked.
    match /live_published_questions/{docId} {
      allow read, write: if false;
    }

    // ─── Access control (new — server-only) ────────────────────────
    match /plans/{planId} {
      allow read, write: if false;     // surfaced via listPlans callable
    }

    match /promo_codes/{code} {
      allow read, write: if false;
      match /redemptions/{uid} {
        allow read: if isSelf(uid);
        allow write: if false;
      }
    }

    match /subscriptions/{subId}     { allow read, write: if false; }
    match /payments/{paymentId}      { allow read, write: if false; }
    match /audit_logs/{logId}        { allow read, write: if false; }
    match /rate_limits/{id}          { allow read, write: if false; }
    match /ip_rate_limits/{id}       { allow read, write: if false; }
    match /promo_campaigns/{id}      { allow read, write: if false; }
    match /email_overrides/{email}   { allow read, write: if false; }
    // Product events — write directly or via logEvent callable, read via
    // admin_listEvents callable. Client has append-only (create) permissions.
    match /events/{eventId}          { allow create: if signedIn(); allow read, update, delete: if false; }
    // Step 1B.5 redemptions subcollection: read self only (via callable
    // is the primary path; this rule is the back-compat for direct read).
    // Already covered by promo_codes/* deny — but redemptions subcoll
    // can be opened from admin SDK and that bypasses rules.

    // Kill-switch / config — public read, no client writes.
    match /app_config/{docId}        { allow read: if true; allow write: if false; }
  }
}
